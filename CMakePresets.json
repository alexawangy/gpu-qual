{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "GPUQUAL_ENABLE_WARNINGS": "ON",
        "GPUQUAL_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "dev",
      "displayName": "Development",
      "description": "Debug build with compile commands exported.",
      "inherits": "ninja-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized release build.",
      "inherits": "ninja-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Release With Debug Info",
      "description": "Optimized build with debug symbols for production diagnostics.",
      "inherits": "ninja-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "strict",
      "displayName": "Strict Development",
      "description": "Debug build with warnings treated as errors.",
      "inherits": "ninja-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GPUQUAL_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "displayName": "Build Development",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Build Release With Debug Info",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "strict",
      "displayName": "Build Strict Development",
      "configurePreset": "strict"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "displayName": "Test Development",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "displayName": "Test Release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Test Release With Debug Info",
      "configurePreset": "relwithdebinfo",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "strict",
      "displayName": "Test Strict Development",
      "configurePreset": "strict",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
