{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "required": [
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1",
      "description": "JSON schema version"
    },
    "expected": {
      "type": "object",
      "description": "Identity requirements. All fields are optional; missing fields are not checked.",
      "properties": {
        "gpu_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4294967295,
          "description": "Number of physical GPUs expected"
        },
        "allowed_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Allowed NVML GPU product names"
        },
        "min_memory_mib": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18446744073709551615,
          "description": "Minimum memory per physical GPU in mebibytes (1 MiB = 1024^2 bytes)"
        },
        "min_driver_version": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[0-9]+(?:\\.[0-9]+)*$",
          "description": "Minimum acceptable NVIDIA driver version, such as 550.90.07"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
